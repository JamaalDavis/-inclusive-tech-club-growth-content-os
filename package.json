{
  "name": "inclusive-tech-club-growth-content-os",
  "version": "0.1.0",
  "description": "Content operations system for Inclusive Tech Club — plan, generate, repurpose, govern, and measure inclusive design content.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "npx tsx scripts/demo.ts",
    "demo:framework": "npx tsx scripts/demo-framework.ts",
    "watch": "python .claude/agents/hooks.py watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
